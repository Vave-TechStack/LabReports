generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  LAB_ASSISTANT
  DOCTOR
  PATIENT
  RECEPTIONIST
  PHLEBOTOMIST
  ACCOUNTANT
  FRANCHISE
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum BloodGroup {
  A_POSITIVE
  A_NEGATIVE
  B_POSITIVE
  B_NEGATIVE
  AB_POSITIVE
  AB_NEGATIVE
  O_POSITIVE
  O_NEGATIVE
}

enum AppointmentType {
  AT_CLINIC
  HOME_COLLECTION
}

enum BookingStatus {
  PENDING
  CONFIRMED
  SAMPLE_COLLECTED
  LAB_PROCESSING
  DOCTOR_VERIFICATION
  REPORT_READY
  DELIVERED
  CANCELLED
}

enum PaymentGateway {
  RAZORPAY
  PHONEPE
  STRIPE
  CASH
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum SampleType {
  BLOOD
  URINE
  STOOL
  SPUTUM
  SWAB
  TISSUE
  OTHER
}

enum InventoryType {
  REAGENT
  CONSUMABLE
  MEDICINE
  EQUIPMENT
  OTHER
}

enum NotificationType {
  BOOKING_CONFIRMED
  PAYMENT_SUCCESS
  SAMPLE_COLLECTED
  REPORT_READY
  APPOINTMENT_REMINDER
  HOME_COLLECTION_REMINDER
  PROMOTION
}

model User {
  id              String   @id @default(uuid())
  email           String   @unique
  phone           String   @unique
  password        String
  role            UserRole @default(PATIENT)
  isVerified      Boolean  @default(false)
  twoFactorSecret String?
  refreshToken    String?
  lastLogin       DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  isActive        Boolean  @default(true)
  isDeleted       Boolean  @default(false)

  patient      Patient?
  doctor       Doctor?
  labAssistant LabAssistant?
  employee     Employee?
  notifications Notification[]
  auditLogs    AuditLog[]
  otps         OTP[]
  assignedLeads      Lead[]
  assignedTickets    SupportTicket[]
  assignedFollowUps  FollowUp[]
  campaignCreated    Campaign[]

  @@map("users")
}

model OTP {
  id        String   @id @default(uuid())
  userId    String
  otp       String
  type      String   @default("LOGIN")
  expiresAt DateTime
  isUsed    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("otps")
}

model Patient {
  id             String     @id @default(uuid())
  userId         String     @unique
  firstName      String
  lastName       String
  dateOfBirth    DateTime?
  gender         Gender?
  bloodGroup     BloodGroup?
  address        String?
  city           String?
  state          String?
  pincode        String?
  avatar         String?
  medicalHistory String?
  allergies      String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookings Booking[]
  reports  Report[]
  invoices Invoice[]

  @@map("patients")
}

model Doctor {
  id                 String   @id @default(uuid())
  userId             String   @unique
  firstName          String
  lastName           String
  specialization     String
  qualification      String
  experience         Int
  registrationNumber String   @unique
  signature          String?
  bio                String?
  isAvailable        Boolean  @default(true)
  consultationFee    Float?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  verifiedReports Report[]          @relation("DoctorVerifiedReports")
  doctorBranches  DoctorBranch[]

  @@map("doctors")
}

model LabAssistant {
  id         String   @id @default(uuid())
  userId     String   @unique
  firstName  String
  lastName   String
  employeeId String   @unique
  branchId   String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  branch           Branch         @relation(fields: [branchId], references: [id])
  processedReports Report[]       @relation("LabAssistantReports")
  sampleEntries    SampleEntry[]

  @@map("lab_assistants")
}

model Employee {
  id          String   @id @default(uuid())
  userId      String   @unique
  firstName   String
  lastName    String
  employeeId  String   @unique
  department  String
  designation String
  branchId    String
  joiningDate DateTime
  salary      Float?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  branch     Branch     @relation(fields: [branchId], references: [id])
  attendance   Attendance[]
  leaveRequests LeaveRequest[]
  shifts       Shift[]
  payroll      Payroll[]

  @@map("employees")
}

model Branch {
  id          String   @id @default(uuid())
  name        String
  code        String   @unique
  address     String
  city        String
  state       String
  pincode     String
  phone       String
  email       String
  latitude    Float?
  longitude   Float?
  isMainLab   Boolean  @default(false)
  openingTime String   @default("08:00")
  closingTime String   @default("20:00")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  labAssistants  LabAssistant[]
  employees      Employee[]
  bookings       Booking[]
  doctorBranches DoctorBranch[]
  inventories    Inventory[]
  purchaseOrders PurchaseOrder[]
  expenses       Expense[]

  @@map("branches")
}

model TestCategory {
  id          String   @id @default(uuid())
  name        String   @unique
  slug        String   @unique
  description String?
  image       String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tests Test[]

  @@map("test_categories")
}

model Test {
  id                      String     @id @default(uuid())
  name                    String
  code                    String     @unique
  categoryId              String
  description             String
  shortDescription        String?
  price                   Float
  discountPrice           Float?
  preparationInstructions String?
  reportTime              String     @default("24 hours")
  sampleType              SampleType @default(BLOOD)
  isPopular               Boolean    @default(false)
  isFeatured              Boolean    @default(false)
  image                   String?
  parameters              Json?
  createdAt               DateTime   @default(now())
  updatedAt               DateTime   @updatedAt

  category           TestCategory       @relation(fields: [categoryId], references: [id])
  healthPackageTests HealthPackageTest[]
  bookingTests       BookingTest[]

  @@map("tests")
}

model HealthPackage {
  id               String   @id @default(uuid())
  name             String
  slug             String   @unique
  description      String
  shortDescription String?
  price            Float
  discountPrice    Float?
  reportTime       String   @default("48 hours")
  isPopular        Boolean  @default(false)
  isFeatured       Boolean  @default(false)
  image            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  tests           HealthPackageTest[]
  bookingPackages BookingPackage[]

  @@map("health_packages")
}

model HealthPackageTest {
  healthPackageId String
  testId          String

  healthPackage HealthPackage @relation(fields: [healthPackageId], references: [id], onDelete: Cascade)
  test          Test          @relation(fields: [testId], references: [id], onDelete: Cascade)

  @@id([healthPackageId, testId])
  @@map("health_package_tests")
}

model Booking {
  id                 String          @id @default(uuid())
  bookingNumber      String          @unique
  patientId          String
  branchId           String?
  type               AppointmentType @default(AT_CLINIC)
  status             BookingStatus   @default(PENDING)
  totalAmount        Float
  discountAmount     Float           @default(0)
  finalAmount        Float
  appointmentDate    DateTime
  appointmentTime    String
  address            String?
  notes              String?
  sampleCollectedAt  DateTime?
  labProcessingAt    DateTime?
  reportReadyAt      DateTime?
  deliveredAt        DateTime?
  cancelledAt        DateTime?
  cancellationReason String?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  patient         Patient          @relation(fields: [patientId], references: [id])
  branch          Branch?          @relation(fields: [branchId], references: [id])
  payments        Payment[]
  report          Report?
  invoice         Invoice?
  bookingTests    BookingTest[]
  bookingPackages BookingPackage[]
  sampleEntry     SampleEntry?
  tickets         SupportTicket[]

  @@map("bookings")
}

model BookingTest {
  bookingId String
  testId    String
  price     Float

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  test    Test    @relation(fields: [testId], references: [id])

  @@id([bookingId, testId])
  @@map("booking_tests")
}

model BookingPackage {
  bookingId String
  packageId String
  price     Float

  booking Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  package HealthPackage @relation(fields: [packageId], references: [id])

  @@id([bookingId, packageId])
  @@map("booking_packages")
}

model Payment {
  id              String        @id @default(uuid())
  bookingId       String
  orderId         String        @unique
  paymentId       String?
  gateway         PaymentGateway
  amount          Float
  status          PaymentStatus @default(PENDING)
  currency        String        @default("INR")
  gatewayResponse Json?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  booking Booking @relation(fields: [bookingId], references: [id])

  @@map("payments")
}

model Report {
  id             String   @id @default(uuid())
  bookingId      String   @unique
  patientId      String
  doctorId       String?
  labAssistantId String?
  reportNumber   String   @unique
  pdfUrl         String?
  parameters     Json
  notes          String?
  isVerified     Boolean  @default(false)
  verifiedAt     DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  booking     Booking      @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  patient     Patient      @relation(fields: [patientId], references: [id])
  verifiedBy  Doctor?      @relation("DoctorVerifiedReports", fields: [doctorId], references: [id])
  processedBy LabAssistant? @relation("LabAssistantReports", fields: [labAssistantId], references: [id])

  @@map("reports")
}

model Invoice {
  id             String   @id @default(uuid())
  invoiceNumber  String   @unique
  bookingId      String   @unique
  patientId      String
  gstNumber      String?
  subtotal       Float
  gstAmount      Float
  discountAmount Float   @default(0)
  totalAmount    Float
  isPaid         Boolean  @default(false)
  paidAt         DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  patient Patient @relation(fields: [patientId], references: [id])

  @@map("invoices")
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  title     String
  message   String
  type      NotificationType
  isRead    Boolean          @default(false)
  metadata  Json?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model SampleEntry {
  id              String     @id @default(uuid())
  bookingId       String     @unique
  barcode         String     @unique
  labAssistantId  String
  sampleType      SampleType
  collectionDate  DateTime
  collectionTime  String
  collectionPlace String?
  notes           String?
  isProcessed     Boolean    @default(false)
  processedAt     DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  booking      Booking      @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  labAssistant LabAssistant @relation(fields: [labAssistantId], references: [id])

  @@map("sample_entries")
}

model DoctorBranch {
  doctorId String
  branchId String

  doctor Doctor @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@id([doctorId, branchId])
  @@map("doctor_branches")
}

model Inventory {
  id         String        @id @default(uuid())
  branchId   String
  itemName   String
  itemType   InventoryType
  quantity   Int
  unit       String
  minQuantity Int          @default(10)
  price      Float
  supplierId String?
  expiryDate DateTime?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  branch   Branch    @relation(fields: [branchId], references: [id])
  supplier Supplier? @relation(fields: [supplierId], references: [id])

  @@map("inventory")
}

enum PurchaseOrderStatus {
  PENDING
  APPROVED
  ORDERED
  PARTIALLY_RECEIVED
  RECEIVED
  CANCELLED
}

model Supplier {
  id            String   @id @default(uuid())
  name          String
  contactPerson String
  phone         String
  email         String
  address       String
  city          String
  state         String
  pincode       String
  gstNumber     String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  inventory      Inventory[]
  purchaseOrders PurchaseOrder[]

  @@map("suppliers")
}

model PurchaseOrder {
  id              String               @id @default(uuid())
  orderNumber     String               @unique
  supplierId      String
  branchId        String
  status          PurchaseOrderStatus  @default(PENDING)
  items           Json
  subtotal        Float
  taxAmount       Float                @default(0)
  totalAmount     Float
  notes           String?
  orderedAt       DateTime?
  expectedAt      DateTime?
  receivedAt      DateTime?
  createdBy       String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  supplier Supplier @relation(fields: [supplierId], references: [id])
  branch   Branch   @relation(fields: [branchId], references: [id])

  @@map("purchase_orders")
}

model Attendance {
  id         String   @id @default(uuid())
  employeeId String
  date       DateTime
  checkIn    DateTime?
  checkOut   DateTime?
  status     String   @default("PRESENT")
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, date])
  @@map("attendance")
}

enum LeaveType {
  EARNED
  SICK
  CASUAL
  MATERNITY
  PATERNITY
  OTHER
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

model LeaveRequest {
  id          String     @id @default(uuid())
  employeeId  String
  type        LeaveType  @default(EARNED)
  startDate   DateTime
  endDate     DateTime
  reason      String
  status      LeaveStatus @default(PENDING)
  approvedBy  String?
  approvedAt  DateTime?
  rejectionReason String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@map("leave_requests")
}

enum ShiftType {
  MORNING
  AFTERNOON
  NIGHT
  GENERAL
}

model Shift {
  id          String    @id @default(uuid())
  employeeId  String
  date        DateTime
  type        ShiftType @default(GENERAL)
  startTime   String
  endTime     String
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, date])
  @@map("shifts")
}

enum ExpenseCategory {
  SALARY
  REAGENTS
  CONSUMABLES
  EQUIPMENT
  MAINTENANCE
  UTILITIES
  RENT
  MARKETING
  TRAVEL
  TRAINING
  PROFESSIONAL_FEES
  INSURANCE
  TAXES
  MISCELLANEOUS
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  CHEQUE
  CREDIT_CARD
  UPI
  OTHER
}

model Expense {
  id            String          @id @default(uuid())
  category      ExpenseCategory @default(MISCELLANEOUS)
  amount        Float
  description   String
  date          DateTime
  branchId      String?
  paymentMethod PaymentMethod   @default(CASH)
  vendor        String?
  invoiceRef    String?
  notes         String?
  createdBy     String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  branch Branch? @relation(fields: [branchId], references: [id])

  @@map("expenses")
}

enum PayrollStatus {
  PENDING
  PROCESSED
  PAID
}

model Payroll {
  id           String        @id @default(uuid())
  employeeId   String
  month        Int
  year         Int
  basicSalary  Float
  allowances   Float         @default(0)
  deductions   Float         @default(0)
  netSalary    Float
  status       PayrollStatus @default(PENDING)
  paymentDate  DateTime?
  notes        String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, month, year])
  @@map("payroll")
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String
  action    String
  entity    String
  entityId  String?
  oldValue  Json?
  newValue  Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}

model ContactMessage {
  id        String   @id @default(uuid())
  name      String
  email     String
  phone     String?
  subject   String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("contact_messages")
}

model Blog {
  id          String    @id @default(uuid())
  title       String
  slug        String    @unique
  excerpt     String
  content     String
  author      String
  image       String?
  tags        String[]
  published   Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("blogs")
}

model Testimonial {
  id         String   @id @default(uuid())
  name       String
  role       String?
  content    String
  rating     Int      @default(5)
  image      String?
  isFeatured Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@map("testimonials")
}

model FAQ {
  id        String   @id @default(uuid())
  question  String
  answer    String
  category  String?
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("faqs")
}

model Career {
  id           String   @id @default(uuid())
  title        String
  department   String
  location     String
  type         String   @default("Full-time")
  description  String
  requirements String[]
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("careers")
}

// ===== CRM Models =====

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  PROPOSAL
  CONVERTED
  LOST
}

enum LeadSource {
  WEBSITE
  REFERRAL
  SOCIAL_MEDIA
  CAMPAIGN
  WALK_IN
  PHONE
  OTHER
}

model Lead {
  id           String     @id @default(uuid())
  firstName    String
  lastName     String?
  email        String?
  phone        String?
  source       LeadSource @default(WEBSITE)
  status       LeadStatus @default(NEW)
  notes        String?
  assignedTo   String?
  convertedAt  DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  assignedToUser User?        @relation(fields: [assignedTo], references: [id])
  followUps      FollowUp[]

  @@map("leads")
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model SupportTicket {
  id           String         @id @default(uuid())
  ticketNumber String         @unique
  subject      String
  description  String
  status       TicketStatus   @default(OPEN)
  priority     TicketPriority @default(MEDIUM)
  customerName String
  customerEmail String?
  customerPhone String?
  assignedTo   String?
  bookingId    String?
  resolution   String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  assignedToUser User?      @relation(fields: [assignedTo], references: [id])
  booking        Booking?   @relation(fields: [bookingId], references: [id])
  messages       TicketMessage[]
  followUps      FollowUp[]

  @@map("support_tickets")
}

model TicketMessage {
  id        String   @id @default(uuid())
  ticketId  String
  sender    String
  message   String
  isStaff   Boolean  @default(false)
  createdAt DateTime @default(now())

  ticket SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@map("ticket_messages")
}

enum FollowUpStatus {
  PENDING
  COMPLETED
  CANCELLED
}

model FollowUp {
  id         String         @id @default(uuid())
  leadId     String?
  ticketId   String?
  title      String
  description String?
  dueDate    DateTime
  status     FollowUpStatus @default(PENDING)
  assignedTo String?
  completedAt DateTime?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  lead            Lead?  @relation(fields: [leadId], references: [id], onDelete: Cascade)
  ticket          SupportTicket? @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  assignedToUser  User?  @relation(fields: [assignedTo], references: [id])

  @@map("follow_ups")
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  SENDING
  SENT
  CANCELLED
}

enum CampaignType {
  EMAIL
  SMS
  WHATSAPP
}

model Campaign {
  id          String         @id @default(uuid())
  name        String
  type        CampaignType   @default(EMAIL)
  subject     String?
  message     String
  audience    Json?
  status      CampaignStatus @default(DRAFT)
  scheduledAt DateTime?
  sentAt      DateTime?
  createdBy   String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  createdByUser User? @relation(fields: [createdBy], references: [id])

  @@map("campaigns")
}
